{
  "compilerOptions": {
    // Strictness
    "strict": true,
    "exactOptionalPropertyTypes": false,

    // Module / Resolution
    "module": "preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"]
    },

    // Types
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "types": [
      "node",
      "react",
      "react-dom",
      "vite/client",
      "vite-plugin-svgr/client"
    ],
    "typeRoots": ["./node_modules", "./node_modules/@types"],

    // Others
    "jsx": "react-jsx",
    "allowJs": true,
    "skipLibCheck": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "./dist"
  },

  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "oxfmt.config.ts",
    "oxlint.config.ts",
    "vite.config.ts"
  ]
}
