{
  "name": "nenwdev-2026",
  "version": "1.0.0",
  "private": true,
  "description": "2026-Redesigned version of nenw.dev",
  "license": "MIT",
  "author": "Khinenw",
  "repository": "https://github.com/HelloWorld017/nenwchan3-rewrite",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "pnpm run '/dev:.*/'",
    "dev:frontend": "vite",
    "dev:backend": "nenwdev-backend-entrypoint-dev",
    "build": "pnpm run clean && pnpm run '/build:.*/'",
    "build:frontend": "vite build",
    "build:backend": "vite build --mode backend",
    "check": "pnpm run '/check:.*/'",
    "check:lint": "pnpm run lint",
    "check:format": "pnpm run format",
    "check:type": "pnpm run typecheck",
    "clean": "rm -rf dist",
    "format": "oxfmt",
    "generate": "pnpm run '/generate:.*/'",
    "generate:i18n": "simplei18n generate -D && oxfmt ./app/i18n",
    "generate:font": "node ./build/fontsubsetter/cli.ts && oxfmt ./app/assets/fonts/generated",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@simplei18n/core": "^0.1.4",
    "@tanstack/react-query": "^5.101.2",
    "es-toolkit": "^1.49.0",
    "hono": "^4.12.28",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@linaria/core": "^8.0.0",
    "@linaria/react": "^8.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@web-alchemy/fonttools": "^1.4.0",
    "@wyw-in-js/vite": "^2.1.0",
    "happy-dom": "^20.0.10",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "tinyglobby": "^0.2.15",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0"
  },
  "packageManager": "pnpm@11.9.0"
}
